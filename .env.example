# BIA Energy — Proveedor Hub · Configuración
# Copiar como .env y llenar los valores reales

# ─── Metabase ───────────────────────────────────────────────────
# URL de tu instancia Metabase (sin / al final)
METABASE_URL=https://metabase.bia.app

# API Key de Metabase (Ajustes → API Keys → Crear key)
# Requiere Metabase ≥ 0.51  (también funciona con token de sesión)
METABASE_API_KEY=mb_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base de datos en Metabase (ver Ajustes → Bases de datos → ID en la URL)
METABASE_DB_ID=1

# Nombres exactos de las tablas (como aparecen en Metabase)
METABASE_SKU_TABLE=sku_catalog
METABASE_OFFERS_TABLE=sku_offers
METABASE_INV_TABLE=inventory_items
METABASE_PROV_TABLE=providers

# ─── Salida ─────────────────────────────────────────────────────
# Ruta del Excel generado (relativa a la raíz del proyecto)
OUTPUT_XLSX=KB_BIA_Proveedores.xlsx
