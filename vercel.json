{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/analyze-catalog.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login", "destination": "/index.html" },
    { "source": "/registro", "destination": "/register.html" },
    { "source": "/inicio", "destination": "/home.html" },
    { "source": "/proveedores", "destination": "/providers.html" },
    { "source": "/cotizaciones", "destination": "/quotes.html" },
    { "source": "/comparativo", "destination": "/compare.html" },
    { "source": "/sku", "destination": "/sku.html" },
    { "source": "/respuesta", "destination": "/respuesta.html" },
    { "source": "/ventas", "destination": "/sales.html" }
  ]
}
